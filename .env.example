# Video Master — environment variables
# Copy to .env.local for local dev. Set the same vars in Lovable → Settings → Env for prod.

# ── PayPlus (Israeli payment gateway) ──────────────────────────────
# Get these from https://payplus.co.il → Dashboard → API Settings
# Leave empty during development → the app falls back to dev-stub mode
# (credits are added locally without real payment).
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAGE_UID=
# Set to "true" only when ready to charge real customers
PAYPLUS_USE_PROD=false

# ── Supabase (database + auth + storage) ───────────────────────────
# Empty = app uses localStorage (dev mode). Fill after migration.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── FFmpeg / Whisper (heavy media processing) ──────────────────────
# Local install paths — usually inherited from PATH on dev machines.
FFMPEG_PATH=ffmpeg
PYTHON_PATH=python

# ── Modal.com (FFmpeg in cloud, for production-scale renders) ──────
# Free $30/mo credit covers ~600 renders for new accounts.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
