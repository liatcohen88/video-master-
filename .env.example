# Video Master — environment variables
# Copy to .env.local for local dev. Set the same vars in Lovable → Settings → Env for prod.

# ── PayPlus (Israeli payment gateway) ──────────────────────────────
# Get these from https://payplus.co.il → Dashboard → API Settings
# Leave empty during development → the app falls back to dev-stub mode
# (credits are added locally without real payment).
PAYPLUS_API_KEY=
PAYPLUS_SECRET_KEY=
PAYPLUS_PAGE_UID=
# Set to "true" only when ready to charge real customers
PAYPLUS_USE_PROD=false

# ── Grow / גראו (Israeli payment gateway) ──────────────────────────
# Dashboard → Settings/API. API access is free — you pay per-transaction.
# GROW_WEBHOOK_SECRET is a random string YOU invent; you put the same value
# in a custom field on the Grow payment page so the webhook can verify.
GROW_PAGE_CODE=
GROW_USER_ID=
GROW_API_KEY=
GROW_WEBHOOK_SECRET=
GROW_USE_PROD=false

# ── Make.com bridge (FREE alternative to Grow's 500₪/mo direct API) ──
# A random string YOU invent. Put the same value in your Make scenario's
# POST body ("secret") so the /api/make/webhook can verify the call.
MAKE_WEBHOOK_SECRET=

# ── Supabase (database + auth + credits store) ─────────────────────
# Empty = app uses localStorage (dev mode). Fill after creating the project.
# Get from: Supabase project → Settings → API.
#   URL + anon key are public (safe in browser).
#   service_role key is SECRET — server only, never expose to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── FFmpeg / Whisper (heavy media processing) ──────────────────────
# Local install paths — usually inherited from PATH on dev machines.
FFMPEG_PATH=ffmpeg
PYTHON_PATH=python

# ── Modal.com (FFmpeg in cloud, for production-scale renders) ──────
# Free $30/mo credit covers ~600 renders for new accounts.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
